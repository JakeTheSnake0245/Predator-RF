# ============================================================
# Predator-RF backend env — copy to /etc/predator-rf/predator-rf.env
# and fill in fleet + token. Every flag has a safe default; the
# only REQUIRED edits before going live are FLEET_NODES and
# API_BEARER_TOKEN (anything else can ship as-is).
# ============================================================

# ── API server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Fleet (REQUIRED for anything to work) ─────────────────────
# Format: id@host:port:apikey:hardware,id2@host2:port2:key2:hw2
# hardware ∈ {hackrf, rtlsdr, bladerf, usrp, airspy, lime}
# Example with two nodes:
#FLEET_NODES=alpha@192.168.10.20:5259:CHANGE_ME:hackrf,bravo@192.168.10.21:5259:CHANGE_ME:rtlsdr
FLEET_NODES=

# ── Auth (STRONGLY recommended for any LAN-exposed deploy) ────
# Empty = open API (lab posture). For field use, generate with:
#   openssl rand -hex 32
API_BEARER_TOKEN=

# ── Persistence ───────────────────────────────────────────────
PERSISTENCE_ENABLED=true
DATA_DIR=/var/lib/predator-rf
MISSION_DB=mission.db
TRACK_REPLAY_WINDOW_H=24

# ── Logging / observability ───────────────────────────────────
LOG_LEVEL=INFO
# text | json — use json for journald → Loki / Splunk pipelines
LOG_FORMAT=json
METRICS_ENABLED=true

# ── Fusion ────────────────────────────────────────────────────
TRACK_MAINTENANCE_S=10
TRACK_MERGE_S=30
MIN_CONFIDENCE=0.3
TDOA_ENABLED=true
GPS_MAX_AGE_S=60
TIMING_POLL_INTERVAL_S=30
BASELINE_WINDOW_H=24
BASELINE_PRUNE_H=6

# ── CoT / TAK output (RX-only by default — opt in to TX) ──────
# OFF by default. Set true ONLY when you've coordinated TX with
# your TOC. Once enabled, the manual-approval gate below adds a
# second human checkpoint before any beacon goes out.
COT_ENABLED=false
COT_DEST_HOST=239.2.3.1
COT_DEST_PORT=6969
COT_UID_PREFIX=PREDATOR
COT_STALE_S=300
COT_MULTICAST_TTL=1
# Two-key gate — operator must POST /api/v1/approvals/{id}/approve
COT_REQUIRE_MANUAL_APPROVAL=true
COT_APPROVAL_EXPIRY_S=7200
COT_APPROVAL_MAX_PENDING=200

# ── AutoTasker (RX-only by default — opt in to RE-TUNE the SDRs) ─
# OFF by default. When enabled, high-threat assessments cause the
# fusion engine to re-tune the recommended sensor nodes via Kujhad.
# This emits commands TO the C++ nodes, but no RF goes out.
AUTO_TASKER_ENABLED=false
AUTO_TASKER_MIN_INTERVAL_S=30
# Fleet-wide brake — at most N tunes per minute across ALL nodes.
# Safety net against an assessment-loop bug thrashing the fleet.
AUTO_TASKER_GLOBAL_MAX_PER_MIN=30

# ── CoC (Center-of-Control) aggregation ───────────────────────
# Only enable on the TOC workstation; field stations stay off.
COC_MODE_ENABLED=false
COC_UPSTREAM_URLS=
COC_RECONNECT_DELAY_S=5
COC_DEDUP_INTERVAL_S=15
COC_DEDUP_FREQ_TOL_HZ=5000
COC_DEDUP_LOC_TOL_M=500

# ── Shutdown ──────────────────────────────────────────────────
# How long stop() waits for in-flight DB / CoT / TDOA tasks to
# drain before forcing cancel on SIGTERM. 5 s is plenty for the
# typical mission DB write; raise if you have a slow USB stick.
SHUTDOWN_DRAIN_TIMEOUT_S=5
